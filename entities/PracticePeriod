{
    "name": "PracticePeriod",
    "type": "object",
    "properties": {
        "name": {
            "type": "string",
            "description": "Numele perioadei de practic\u0103 (ex: Practica de Iarn\u0103 2024)"
        },
        "startDate": {
            "type": "string",
            "format": "date",
            "description": "Data de \u00eenceput a perioadei"
        },
        "endDate": {
            "type": "string",
            "format": "date",
            "description": "Data de final a perioadei"
        },
        "checkinStartTime": {
            "type": "string",
            "description": "Ora de inceput pentru pontaj in perioada (HH:mm, optional)"
        },
        "checkinEndTime": {
            "type": "string",
            "description": "Ora de final pentru pontaj in perioada (HH:mm, optional)"
        },
        "className": {
            "type": "string",
            "description": "Clasa pentru care se aplic\u0103 (op\u021bional - dac\u0103 lipse\u0219te, se aplic\u0103 tuturor)"
        },
        "operatorId": {
            "type": "string",
            "description": "Operator specific (op\u021bional - dac\u0103 lipse\u0219te, se aplic\u0103 tuturor)"
        },
        "description": {
            "type": "string",
            "description": "Descriere sau noti\u021be despre perioad\u0103"
        },
        "isActive": {
            "type": "boolean",
            "default": true,
            "description": "Perioada activ\u0103 sau nu"
        }
    },
    "required": [
        "name",
        "startDate",
        "endDate"
    ]
}
